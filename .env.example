# Increa Reader — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────
# Anthropic API key for Claude chat features
ANTHROPIC_API_KEY=

# Repository paths (colon-separated for multiple repos)
INCREA_REPO=/path/to/your/repo

# ── Optional ──────────────────────────────────────────
# Server port (default: 3000)
# PORT=3000

# Anthropic base URL (for proxy or custom endpoint)
# ANTHROPIC_BASE_URL=

# Anthropic auth token (alternative to API key)
# ANTHROPIC_AUTH_TOKEN=

# AI provider: anthropic (default) or openai
# AI_PROVIDER=anthropic

# OpenAI configuration (when AI_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# Chat logs directory (default: chat-logs, supports ~ expansion)
# CHAT_LOGS_DIR=chat-logs

# Debug mode (default: false)
# DEBUG=false