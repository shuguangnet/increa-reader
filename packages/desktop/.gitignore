# Tauri
src-tauri/target/
src-tauri/gen/

# Sidecar binaries (keep .gitkeep, ignore actual binaries)
src-tauri/binaries/python-server-*
!src-tauri/binaries/.gitkeep

# Android signing (never commit real keystore passwords)
src-tauri/keystore.properties
src-tauri/debug.keystore
src-tauri/release.keystore
src-tauri/gen/android/keystore.properties
src-tauri/gen/android/gradle.properties

