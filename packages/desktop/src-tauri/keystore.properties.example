# Increa Reader — Android Keystore Properties (Template)
#
# Copy this file to keystore.properties and fill in your signing details.
# This file is used by the Tauri Android build to sign release APKs/AABs.
#
# IMPORTANT: Never commit keystore.properties with real passwords to git!
# It's already listed in .gitignore.

storeFile=debug.keystore
storePassword=android
keyAlias=increa_debug
keyPassword=android