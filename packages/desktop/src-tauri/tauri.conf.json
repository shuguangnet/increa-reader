{
  "productName": "Increa Reader",
  "version": "1.0.0",
  "identifier": "com.increa.reader",
  "build": {
    "beforeDevCommand": "pnpm --filter @increa-reader/desktop dev:vite",
    "devUrl": "http://localhost:5177",
    "beforeBuildCommand": "pnpm --filter @increa-reader/desktop build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https: wss:"
    },
    "windows": [
      {
        "title": "Increa Reader",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage", "ios", "apk", "aab"],
    "externalBin": ["binaries/python-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/AppIcon-20x20@2x.png",
      "icons/AppIcon-20x20@3x.png",
      "icons/AppIcon-29x29@2x.png",
      "icons/AppIcon-29x29@3x.png",
      "icons/AppIcon-40x40@2x.png",
      "icons/AppIcon-40x40@3x.png",
      "icons/AppIcon-60x60@2x.png",
      "icons/AppIcon-60x60@3x.png",
      "icons/AppIcon-76x76.png",
      "icons/AppIcon-76x76@2x.png",
      "icons/AppIcon-83.5x83.5@2x.png",
      "icons/AppIcon-1024x1024.png"
    ],
    "resources": [],
    "category": "Productivity",
    "shortDescription": "个人知识库阅读器",
    "longDescription": "Increa Reader 是一个现代化的知识管理工具，支持文件浏览、全文搜索、AI 对话和 PDF 阅读。",
    "iOS": {
      "frameworks": [],
      "minimumSystemVersion": "15.0",
      "developmentTeam": "DEVELOPMENT_TEAM_ID",
      "bundleName": "Increa Reader",
      "bundleShortVersion": "1.0.0",
      "version": "1",
      "infoPlistEntries": {
        "CFBundleLocalizations": ["zh-CN", "en"],
        "UILaunchScreen": {
          "UIColorName": "#1e40af",
          "UIImageName": ""
        },
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "UIStatusBarStyle": "UIStatusBarStyleDefault",
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIRequiresFullScreen": false,
        "NSPhotoLibraryUsageDescription": "Increa Reader 需要访问相册以便上传图片到对话中。",
        "NSCameraUsageDescription": "Increa Reader 需要使用相机以便拍照并上传到对话中。",
        "NSDocumentsFolderUsageDescription": "Increa Reader 需要访问文档以便浏览和阅读文件。",
        "NSLocalNetworkUsageDescription": "Increa Reader 需要访问本地网络以连接后端服务。",
        "ITSAppUsesNonExemptEncryption": false,
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "NSFaceIDUsageDescription": "Increa Reader 使用 Face ID 保护您的私人知识库。",
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false
        },
        "LSApplicationQueriesSchemes": ["fbapi", "twitter", "whatsapp"],
        "NSBluetoothAlwaysUsageDescription": "Increa Reader 使用蓝牙进行设备间数据同步。",
        "UIBackgroundModes": ["remote-notification"],
        "UIStatusBarStyle~iphone": "UIStatusBarStyleLightContent",
        "UIStatusBarStyle~ipad": "UIStatusBarStyleDefault",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "PDF Document",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": ["com.adobe.pdf"],
            "CFBundleTypeRole": "Viewer"
          },
          {
            "CFBundleTypeName": "Markdown Document",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": ["net.daringfireball.markdown"],
            "CFBundleTypeRole": "Viewer"
          }
        ],
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.adobe.pdf",
            "UTTypeConformsTo": ["public.data"],
            "UTTypeDescription": "PDF Document",
            "UTTypeTagSpecification": {
              "public.filename-extension": ["pdf"],
              "public.mime-type": ["application/pdf"]
            }
          },
          {
            "UTTypeIdentifier": "net.daringfireball.markdown",
            "UTTypeConformsTo": ["public.plain-text"],
            "UTTypeDescription": "Markdown Document",
            "UTTypeTagSpecification": {
              "public.filename-extension": ["md", "markdown"],
              "public.mime-type": ["text/markdown"]
            }
          }
        ]
      }
    },
    "android": {
      "minSdkVersion": 26,
      "targetSdkVersion": 34,
      "versionCode": 1,
      "versionName": "1.0.0",
      "splitModulesEnabled": false,
      "allowBackup": false,
      "abiFilters": ["arm64-v8a", "x86_64"],
      "adaptiveIcon": {
        "foreground": "icons/android-icons/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "background": "icons/android-icons/mipmap-xxxhdpi/ic_launcher_background.png"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "IncreaReader.entitlements",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": null,
        "allowDowngrades": true,
        "allowToChangeInstallationDirectory": true,
        "installerHooks": null
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"],
        "desktop": {
          "Name": "Increa Reader",
          "Comment": "个人知识库阅读器",
          "Categories": ["Productivity", "Education", "Utility"],
          "Keywords": ["knowledge", "reader", "pdf", "notes"],
          "StartupWMClass": "increa-reader",
          "Type": "Application"
        }
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "libappindicator-gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "mobile": {
    "ios": {
      "minimumSystemVersion": "15.0"
    },
    "android": {
      "minSdkVersion": 26,
      "targetSdkVersion": 34
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "python-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "deep-link": {
      "mobile": [
        {
          "host": "increa.reader",
          "pathPrefix": "/open"
        }
      ]
    },
    "updater": {
      "active": false,
      "endpoints": [],
      "dialog": true,
      "pubkey": ""
    }
  }
}