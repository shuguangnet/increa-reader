{
  "productName": "Increa Reader",
  "version": "1.0.0",
  "identifier": "com.increa.reader",
  "build": {
    "beforeDevCommand": "pnpm --filter @increa-reader/desktop dev:vite",
    "devUrl": "http://localhost:5177",
    "beforeBuildCommand": "pnpm --filter @increa-reader/desktop build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*"
    },
    "windows": [
      {
        "title": "Increa Reader",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "msi", "nsis", "ios", "android"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": []
  },
  "mobile": {
    "ios": {
      "minimumSystemVersion": "15.0"
    },
    "android": {
      "minSdkVersion": 26,
      "targetSdkVersion": 34
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "python-server",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
