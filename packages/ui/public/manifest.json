{
  "name": "Increa Reader",
  "short_name": "Increa",
  "description": "你的个人知识库，快速访问文件与笔记",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#1e293b",
  "orientation": "any",
  "scope": "/",
  "lang": "zh-CN",
  "dir": "ltr",
  "categories": ["productivity", "education"],
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/screenshots/home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Increa Reader 首页"
    },
    {
      "src": "/screenshots/ai-chat.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AI 智能对话"
    },
    {
      "src": "/screenshots/pdf-reader.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "PDF 阅读器"
    },
    {
      "src": "/screenshots/mobile-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Increa Reader 移动端首页"
    },
    {
      "src": "/screenshots/mobile-file.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "文件查看"
    },
    {
      "src": "/screenshots/mobile-ai.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "移动端 AI 对话"
    }
  ],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+increa",
      "url": "/?action=open&path=%s"
    }
  ],
  "shortcuts": [
    {
      "name": "搜索",
      "short_name": "搜索",
      "description": "搜索文件内容",
      "url": "/?action=search",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "AI 对话",
      "short_name": "AI",
      "description": "与 AI 助手对话",
      "url": "/?action=ai-chat",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["text/markdown", "text/plain", "application/pdf", "text/html"]
        }
      ]
    }
  }
}