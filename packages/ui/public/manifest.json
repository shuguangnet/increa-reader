{
  "name": "Increa Reader",
  "short_name": "Increa",
  "description": "你的个人知识库，快速访问文件与笔记",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#1e293b",
  "orientation": "any",
  "screenshots": [
    {
      "src": "/screenshots/home.svg",
      "sizes": "1280x720",
      "type": "image/svg+xml",
      "form_factor": "wide",
      "label": "Increa Reader 首页"
    },
    {
      "src": "/screenshots/mobile-home.svg",
      "sizes": "390x844",
      "type": "image/svg+xml",
      "form_factor": "narrow",
      "label": "Increa Reader 移动端首页"
    },
    {
      "src": "/screenshots/mobile-file.svg",
      "sizes": "390x844",
      "type": "image/svg+xml",
      "form_factor": "narrow",
      "label": "文件查看"
    }
  ],
  "icons": [
    {
      "src": "/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "categories": ["productivity", "education"],
  "lang": "zh-CN",
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "搜索",
      "short_name": "搜索",
      "description": "搜索文件内容",
      "url": "/?action=search",
      "icons": [{ "src": "/icon-192.svg", "sizes": "192x192" }]
    },
    {
      "name": "AI 对话",
      "short_name": "AI",
      "description": "与 AI 助手对话",
      "url": "/?action=ai-chat",
      "icons": [{ "src": "/icon-192.svg", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["text/markdown", "text/plain", "application/pdf", "text/html"]
        }
      ]
    }
  }
}