# Required: paths to repositories (colon-separated)
INCREA_REPO="/path/to/repo1:/path/to/repo2"

# AI Provider selection: "anthropic" or "openai"
# Default: "anthropic" if ANTHROPIC_API_KEY is set, otherwise "openai"
# AI_PROVIDER=anthropic

# --- Anthropic Claude API (Option A) ---
ANTHROPIC_API_KEY="your-anthropic-api-key"
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=your-proxy-token

# --- OpenAI API (Option B) ---
# OPENAI_API_KEY="your-openai-api-key"
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Optional: server port (default: 3000)
# PORT=3000

# Optional: chat log directory (default: chat-logs)
# CHAT_LOGS_DIR=chat-logs