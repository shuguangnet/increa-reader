# Dependencies
node_modules/
**/node_modules/

# Build artifacts — NOTE: we need packages/ui/dist in the final image so we
# exclude the local dev artefact but keep the builder-stage copy.
*.tsbuildinfo
packages/ui/dist/
!packages/ui/dist/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
*.egg

# Test and coverage
coverage/
.nyc_output/
htmlcov/
.pytest_cache/

# IDE and editor
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# CI
.github/

# Docker
Dockerfile
docker-compose*.yml

# Documentation
README.md
LICENSE
*.md
!packages/*/README.md

# Env and secrets
.DS_Store
.env
.env.*
!.env.example

# Temp files
*.log
temp/
tmp/